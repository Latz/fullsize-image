{
	"name": "Fullsize Image",
	"short_name": "Fullsize",
	"description": "Automatically resize images to fit your browser's viewport. Click the extension icon to toggle between active and sleeping states.",
	"version": "1.1",
	"manifest_version": 3,

	"permissions": ["activeTab", "scripting", "storage", "tabs"],
	"host_permissions": ["<all_urls>"],

	"background": {
		"service_worker": "action.js"
	},

	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"css": ["content.css"],
			"js": ["content.js"],
			"run_at": "document_start",
			"match_about_blank": true,
			"type": "module"
		}
	],

	"action": {
		"default_title": "Fullsize Image Settings",
		"default_popup": "popup.html",
		"default_icon": {
			"128": "icon-active.png"
		}
	},

	"icons": {
		"16": "icon-16.png",
		"48": "icon-48.png",
		"128": "icon-128.png"
	},

	"options_page": "options.html"
}
