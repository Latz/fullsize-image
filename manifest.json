{
	"name": "Fullsize Image",
	"short_name": "Fullsize",
	"description": "Automatically resize images to fit your browser's viewport. Click the extension icon to toggle between active and sleeping states.",
	"version": "1.0",
	"manifest_version": 3,

	"permissions": ["activeTab", "scripting", "storage"],
	"host_permissions": ["<all_urls>"],

	"background": {
		"service_worker": "action.js"
	},

	"action": {
		"default_title": "Toggle image size",
		"default_icon": {
			"128": "icon-active.png"
		}
	},

	"icons": {
		"16": "icon-16.png",
		"48": "icon-48.png",
		"128": "icon-128.png"
	}
}
